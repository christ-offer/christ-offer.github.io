---
// Server ran / terminal ran code
import SiteLayout from '../layouts/SiteLayout.astro'
const posts = await Astro.glob('./posts/*.md');
import Post from '../components/Post.astro'

---
<SiteLayout>
	<main>
		{posts.map(post => (
		<Post class="post-container">
			<a href={post.url}><h2>{post.frontmatter.title}</h2></a>
			<h4>{post.frontmatter.description}</h4>
			<p class="author">{post.frontmatter.author}</p>
		</Post>
		))}
	</main>
</SiteLayout>
<style>
	main {
		max-width:  40%;
		margin:  auto;
		padding:  1rem;
		margin-top: 5rem;
	}
	a {
		text-decoration:  none;
		color: black;
	}
	a:hover {
		text-decoration:  underline;
	}
	h2 {
		border-bottom: 1px solid black;
		font-size: 2rem;
		text-align: center;
	}
	.post-container {
		padding: 1rem;
		border-radius: 2px;
	}
</style>