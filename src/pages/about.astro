---
// Server ran / terminal ran code
import SiteLayout from '../layouts/SiteLayout.astro'

---
<SiteLayout>
	<article>
      <main>
      	<img src="/img/fluffmonster.png" alt="a bat that with flowers and colors around it" width="200" style="margin:auto;">
      	<p>About me you know</p>
      	<p>About the site</p>
      	<p>About projects</p>
      	
      	<h2>some random facts</h2>
      	<ul>
      		<li>thing</li>
      		<li>about</li>
      		<li>another thing</li>
      	</ul>
      	<h2>Projects</h2>
      	<ul>
	      	<li>project 1</li>
    	  	<li>project 2</li>
      		<li>project 3</li>
      	</ul>
      </main>
   </article>
</SiteLayout>
<style>
   article {
   	  width: 100%;
   	  max-width: 70%;
      background-color:  hsl(220, 50%, 95%);
      margin-top: 5rem;
      padding: 1rem;
      border-radius: 2px;
     display: grid;
     grid-column-start:  2;
     place-self: start center;
     overflow: hidden;
   }
   article main {
      padding: 1rem;
      display: grid;
   }
   article main img {
   	border-radius: 5px;
   }
   article h3 {
      padding-bottom: 1rem;
      max-width: 60%;
      place-self: center;
      text-align: center;
   }
   article ul {
   	list-style: square;
   	padding-bottom:  1rem;
   }
   article p {
   	padding-bottom: 1rem;
   }
</style>